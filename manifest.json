{
  "manifest_version": 3,
  "name": "PromptBook",
  "version": "1.0.5",
  "description": "Premium prompt vault that saves, searches, and injects prompts directly into AI chats (ChatGPT, Claude, Perplexity, Gemini).",
  "permissions": ["storage", "activeTab", "scripting", "clipboardWrite", "contextMenus"],
  "host_permissions": [
    "https://chatgpt.com/*", 
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://www.perplexity.ai/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open PromptBook"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*", 
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css", "icons/*"],
      "matches": ["*://chatgpt.com/*", "*://chat.openai.com/*", "*://claude.ai/*", "*://www.perplexity.ai/*", "*://gemini.google.com/*"]
    }
  ]
}
